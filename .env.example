# @zoffwallet/sdk — DevNet smoke test config
#
# Copy to .env.local and fill in the values. .env.local is gitignored.
# Real secrets (where applicable) are delivered out-of-band via Signal.
# The committed .env.example carries no credentials.
#
# Corresponds 1:1 with the "Endpoints & identifiers" table in
# `01-collab-sdk/DevNet env — Toiki delivery — 2026-04-20.md` in the
# Zoff↔Helvetswap shared vault.
#
# --- Variable-by-variable deltas vs. the vault handover ---
#
# AUTH_CLIENT_SECRET: NOT USED. `app-provider-unsafe` is a public Keycloak
# client; the password grant works without a client secret. Kept out of
# this file on purpose so no consumer thinks it's a missing value.
#
# AUTH_EXPECTED_CLAIM_AUD: set to `https://canton.network.global` — NOT
# `app-provider-unsafe`. The client name is a misnomer; real JWT `aud` is
# `["https://canton.network.global", "account"]`. See Signal clarification
# 2026-04-20 (Toiki).
#
# AUTH_BOOTSTRAP_JWT: intentionally omitted. Bootstrap tokens are short-
# lived (~5 min); the SDK mints fresh ones via the password grant. Do not
# paste a live JWT here.

# --- Transport & endpoints ------------------------------------------------

# Ledger-API gRPC (reached via SSH tunnel: -L 5001:localhost:5001)
LEDGER_API_HOST=localhost
LEDGER_API_PORT=5001
LEDGER_API_TLS=false

# Splice scan — used for TransferFactory choice-context lookup
SCAN_URL=https://scan.sv-1.dev.global.canton.network.digitalasset.com
TRANSFER_FACTORY_URL=https://scan.sv-1.dev.global.canton.network.sync.global

# Helvetswap backend (HTTP, ngrok)
HELVETSWAP_BACKEND_URL=https://nonexplicable-lacily-leesa.ngrok-free.dev

# Synchronizer id — VARIES per reset. Resolve at runtime where possible;
# falling back to this only if needed. Live value → Signal.
SYNCHRONIZER_ID=

# --- Canton parties (public identifiers, safe to commit) ------------------

OPERATOR_PARTY_HINT=ClearportX-DEX-1
OPERATOR_PARTY_ID=ClearportX-DEX-1::122081f2b8e29cbe57d1037a18e6f70e57530773b3a4d1bea6bab981b7a76e943b37

ZOFF_TEST_PARTY_HINT=alice
ZOFF_TEST_PARTY_ID=Alice-9cefe94d::1220414f85e74ed69ca162b9874f3cf9dfa94fb4968823bd8ac9755544fcb5d72388

ZOFF_TEST_PARTY_SECONDARY_HINT=bob
ZOFF_TEST_PARTY_SECONDARY_ID=Bob-9b3970be::1220414f85e74ed69ca162b9874f3cf9dfa94fb4968823bd8ac9755544fcb5d72388

# --- Keycloak auth (reached via SSH tunnel: -L 8082:localhost:8082) -------

AUTH_ISSUER_URL=http://localhost:8082/realms/AppProvider
AUTH_JWKS_URL=http://localhost:8082/realms/AppProvider/protocol/openid-connect/certs
AUTH_TOKEN_URL=http://localhost:8082/realms/AppProvider/protocol/openid-connect/token

# Public Keycloak client — password grant, no client_secret needed
AUTH_CLIENT_ID=app-provider-unsafe

# JWT validation
AUTH_EXPECTED_CLAIM_ISS=http://localhost:8082/realms/AppProvider
AUTH_EXPECTED_CLAIM_AUD=https://canton.network.global

# Test user credentials (DevNet-only; real credential → Signal)
AUTH_TEST_USERNAME=alice
AUTH_TEST_PASSWORD=

# --- Canton package pins --------------------------------------------------

LF_VERSION=2.1
HOLDINGPOOL_PACKAGE_ID=782249463e3c27c0ad0ee501dd0f679ccd96abeeea72d54cf1d405a798561843

# --- Smoke test (scripts/smoke-test.ts) -----------------------------------
#
# Only read by the smoke harness, not by the SDK runtime.

# Path to the built `.dar` carrying the canonical daml-script Toiki
# provides. Signal-delivered — do not commit the dar or the path.
DAML_SCRIPT_PATH=

# SSH target used by the log-tail half of the smoke test. If omitted,
# pass `--skip-log-tail` to the smoke script.
DEVNET_SSH_HOST=root@5.9.70.48
DEVNET_SSH_KEY=~/.ssh/zoff_devnet_helvetswap
