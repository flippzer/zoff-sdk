{
  "name": "@zoffwallet/sdk",
  "version": "0.1.0",
  "description": "Reference implementation of @zoffwallet/provider-interface. Browser SDK that translates the canonical CantonWalletProvider contract into HTTP calls against the Zoff wallet backend, with cross-origin popup approval.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build:esm": "tsc -p tsconfig.json",
    "build:cjs": "tsc -p tsconfig.cjs.json && node -e \"require('fs').writeFileSync('dist/cjs/package.json', JSON.stringify({type:'commonjs'}))\"",
    "build": "npm run clean && npm run build:esm && npm run build:cjs",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "canton",
    "wallet",
    "provider",
    "zoff",
    "cip-0103"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/flippzer/zoff-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/flippzer/zoff-sdk/issues"
  },
  "homepage": "https://github.com/flippzer/zoff-sdk#readme",
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "peerDependencies": {
    "@zoffwallet/provider-interface": "^0.1.2"
  },
  "devDependencies": {
    "@zoffwallet/provider-interface": "^0.1.2",
    "@types/node": "^20.12.0",
    "typescript": "^5.4.0"
  }
}
